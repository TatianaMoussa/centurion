import fedoo as fd
import numpy as np

fd.ModelingSpace("3D")

my_mesh = fd.mesh.import_msh("disque_2zones.msh")
print(my_mesh)

mesh_vol = my_mesh["tet4"]   # si erreur, essaie "tet10"

material = fd.constitutivelaw.ElasticIsotrop(2.0, 0.45)
my_weakform = fd.weakform.StressEquilibrium(material)

my_assembly = fd.Assembly.create(my_weakform, mesh_vol)

pb = fd.problem.Linear(my_assembly)
pb.set_solver('cg')

zmin = mesh_vol.bounding_box.zmin
zmax = mesh_vol.bounding_box.zmax

nodes_bottom = mesh_vol.find_nodes('Z', zmin, tol=1e-8)
nodes_top = mesh_vol.find_nodes('Z', zmax, tol=1e-8)

pb.bc.add('Dirichlet', nodes_bottom, 'Disp', 0)
pb.bc.add('Dirichlet', nodes_top, 'DispZ', -0.5)

pb.apply_boundary_conditions()
pb.solve()

res = pb.get_results(my_assembly, ["Stress", "Disp"])
res.plot("Stress", "ZZ", "Node", show_edges=False)